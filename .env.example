# Davnoot — environment variables.
# Copy to .env.local for local dev; set the same keys in Vercel → Settings →
# Environment Variables for production. Never commit real values.

# ---- Database --------------------------------------------------------------
# MongoDB Atlas connection string. Include the database name or set MONGODB_DB.
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="davnoot"

# ---- Writer dashboard auth (/seoteam) --------------------------------------
# The shared password the content team types in. Rotate by changing this value.
SEOTEAM_PASSWORD="choose-a-long-random-passphrase"

# Signs the session cookie (HMAC-SHA256). MUST be long and random — changing it
# invalidates every existing session (which is how you force a logout).
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET="64-hex-chars-from-the-command-above"

# ---- Images (Cloudinary) ---------------------------------------------------
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="123456789012345"
CLOUDINARY_API_SECRET="your-api-secret"
# Folder all dashboard uploads land in.
CLOUDINARY_FOLDER="davnoot/blog"

# ---- Existing: booking form (already live) ---------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxx"
RESEND_FROM="Davnoot Digital <info@davnoot.com>"
LEAD_TO="info@davnoot.com"
